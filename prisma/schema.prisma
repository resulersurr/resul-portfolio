// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  email       String?
  subject     String?
  phone       String?
  message     String
  budget      String?
  timeline    String?
  projectType String?
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)
}

model PaymentNotification {
  id          String   @id @default(uuid())
  serviceName String
  txid        String
  walletAddress String   @default("TWResKHqM7tpuAuFyioAWfQbrj5XfV2LCi")
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  verifiedAt  DateTime?
  notes       String?
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float    @default(0)
  priceUnit   String   @default("USDT")
  icon        String   @default("Code2")
  color       String   @default("from-blue-500 to-indigo-600")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  category    String
  description String
  tech        String   // SQLite doesn't support String[], using comma separated string
  image       String
  link        String?
  github      String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoginAttempt {
  id          String   @id @default(uuid())
  ip          String   @unique
  count       Int      @default(1)
  lastAttempt DateTime @default(now())
}
