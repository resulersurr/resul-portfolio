// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  email       String?
  subject     String?
  phone       String?
  message     String
  budget      String?
  timeline    String?
  projectType String?
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)
}

model PaymentNotification {
  id            String    @id @default(uuid())
  serviceName   String
  txid          String
  walletAddress String    @default("TWResKHqM7tpuAuFyioAWfQbrj5XfV2LCi")
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  verifiedAt    DateTime?
  notes         String?
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float    @default(0)
  priceUnit   String   @default("USDT")
  icon        String   @default("Code2")
  color       String   @default("from-blue-500 to-indigo-600")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  category    String
  description String
  tech        String // SQLite doesn't support String[], using comma separated string
  image       String
  link        String?
  github      String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoginAttempt {
  id          String   @id @default(uuid())
  ip          String   @unique
  count       Int      @default(1)
  lastAttempt DateTime @default(now())
}

model LeadCompany {
  id              String        @id @default(uuid())
  name            String
  sector          String
  district        String
  phone           String
  websiteStatus   String
  leadStatus      String
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  notes           String?
  meetings        LeadMeeting[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model LeadMeeting {
  id          String      @id @default(uuid())
  company     LeadCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  type        String
  scheduledAt DateTime
  status      String
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AIChatSession {
  id        String   @id @default(uuid())
  name      String
  phone     String
  messages  String   // JSON stringified message list
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

